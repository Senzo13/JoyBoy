{
    "_comment": "GPU Profile: 16GB VRAM (RTX 4080, 3080 Ti, etc.)",
    "_vram_range": [14, 18],

    "general": {
        "use_cpu_offload": false,
        "skip_quantization": false,
        "torch_compile": false,
        "warmup_enabled": true
    },

    "image": {
        "visible_models": [
            "epiCRealism XL (Fast)", "epiCRealism XL (Moyen)",
            "Juggernaut XL (Moyen)",
            "CyberRealistic Pony (Moyen)", "CyberRealistic Pony (Normal)",
            "LUSTIFY (Moyen)",
            "Flux Fill INT4",
            "Juggernaut XL v9", "epiCRealism XL", "SDXL Turbo", "Flux Dev INT4",
            "Flux Kontext Q2", "Flux Kontext Q4", "Flux Kontext Q6", "Flux Kontext Q8"
        ],
        "default_inpaint_model": "epiCRealism XL (Moyen)",
        "default_model": "epiCRealism XL (Moyen)",
        "default_steps": 35,
        "default_strength": 0.78,
        "default_dilation": 30,
        "text2img_steps": 35,
        "recommended_models": {
            "inpainting": "epiCRealism XL (Moyen)",
            "generation": "epiCRealism XL"
        }
    },

    "sdxl": {
        "quantization": "int8",
        "offload_strategy": "none",
        "vae_dtype": "float32",
        "vae_slicing": true,
        "vae_tiling": false
    },

    "flux_fill": {
        "quantization": "int4",
        "offload_strategy": "model_cpu_offload",
        "guidance_scale": 30.0,
        "steps": 50,
        "max_resolution": [1024, 1024],
        "_note": "NF4 pré-quantifié (~12GB) + cpu_offload, VRAM < 20GB"
    },

    "flux_kontext": {
        "quantization": "int8",
        "offload_strategy": "model_cpu_offload",
        "guidance_scale": 3.5,
        "steps": 28,
        "lora": "enhanceaiteam/Flux-Uncensored-V2"
    },

    "pose_controlnet": {
        "enabled": true,
        "quantization": "int8",
        "scale": 0.45,
        "strength": 0.75,
        "_note": "OpenPose SDXL INT8, both depth+openpose can coexist in VRAM"
    },

    "video": {
        "default_model": "wan_i2v_720p",
        "wan": {
            "quantization": "int8",
            "offload_strategy": "model_cpu_offload",
            "resolution": "720p",
            "max_frames": 81,
            "guidance_scale": 5.0,
            "steps": 30,
            "fps": 24,
            "vae_dtype": "float32",
            "vae_slicing": true,
            "vae_tiling": false,
            "sage_attention": true
        },
        "ltx": {
            "quantization": "int8",
            "offload_strategy": "model_cpu_offload",
            "resolution": "480p",
            "max_frames": 97,
            "guidance_scale": 1.0,
            "steps": 13,
            "fps": 24
        }
    },

    "ollama": {
        "max_vram_gb": 4,
        "default_chat_model": "qwen2.5:7b",
        "utility_model": "dolphin-phi:2.7b"
    }
}
