#
# JoyBoy provider auth
# - Optional: define provider secrets here for local development
# - or save them from the UI in Settings > Models
# - UI-managed secrets are stored locally outside git in ~/.joyboy/config.json
#
HF_TOKEN=
CIVITAI_API_KEY=

# Optional food/drink image analyzer.
# Downloads lazily from Hugging Face when a food/drink image analysis needs it.
# The model card lists BF16 weights; INT8 is an optional bitsandbytes runtime mode.
JOYBOY_FOODEXTRACT_MODEL=CreatorJarvis/FoodExtract-Vision-SmolVLM2-500M-fine-tune
JOYBOY_FOODEXTRACT_INT8=0
JOYBOY_FOODEXTRACT_KEEP_LOADED=0

# Optional cloud LLM providers for chat/terminal agent mode.
# JoyBoy stays local-first; use provider:model ids such as openai:gpt-4o-mini
# or openrouter:provider/model when a key is configured.
# API keys and subscription/CLI access are separate modes in the UI; selecting
# a subscription connector must not consume the matching API key.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
NOVITA_API_KEY=
MINIMAX_API_KEY=
VOLCENGINE_API_KEY=
ZHIPU_API_KEY=
VLLM_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Optional subscription auth handoffs, compatible with DeerFlow-style setup.
# Codex CLI auth defaults to ~/.codex/auth.json when these are empty.
CODEX_AUTH_PATH=
CODEX_HOME=

# Claude Code OAuth defaults to ~/.claude/.credentials.json when these are empty.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_CREDENTIALS_PATH=

OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional Diffusers-native SDNQ quantization backend.
# If `sdnq` is installed, JoyBoy can auto-register pre-quantized SDNQ Diffusers
# checkpoints and prefer SDNQ post-load quantization on SDXL loaders.
# `JOYBOY_SDNQ_USE_SVD=auto` enables SVD by default for 4-bit SDNQ weights.
JOYBOY_SDNQ_ENABLE=1
JOYBOY_SDNQ_POSTLOAD=1
JOYBOY_SDNQ_AUTO_INSTALL=0
JOYBOY_SDNQ_USE_SVD=auto
JOYBOY_SDNQ_WEIGHTS_DTYPE=
JOYBOY_SDNQ_GROUP_SIZE=0
JOYBOY_SDNQ_SVD_RANK=32
JOYBOY_SDNQ_SVD_STEPS=8

# Optional SignalAtlas connectors and organic-potential enrichments.
# GSC CSV imports work without credentials; these keys unlock future direct/API enrichment.
SIGNALATLAS_GSC_SITE_URL=
SIGNALATLAS_GSC_SERVICE_ACCOUNT_JSON=
SIGNALATLAS_GSC_SERVICE_ACCOUNT_FILE=
SIGNALATLAS_GSC_OAUTH_JSON=
SIGNALATLAS_GSC_OAUTH_FILE=
SEMRUSH_API_KEY=

# Optional PerfAtlas connectors and owner-context enrichments.
# Public Google perf data can use dedicated keys or fall back to GOOGLE_API_KEY.
PAGESPEED_API_KEY=
CRUX_API_KEY=
WEBPAGETEST_API_KEY=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
PERFATLAS_VERCEL_PROJECT_ID=
NETLIFY_AUTH_TOKEN=
PERFATLAS_NETLIFY_SITE_ID=
CLOUDFLARE_API_TOKEN=
PERFATLAS_CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
